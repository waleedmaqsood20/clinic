# ── Retell ────────────────────────────────────────────────────────────────────
# Your Retell API key (dashboard.retellai.com → API Keys).
# Required to create the agent (create-agent.sh) and to verify signatures in prod.
RETELL_API_KEY=

# Public URLs for your server — must be HTTPS and reachable by Retell.
# Set these after deploying (render.yaml/Dockerfile) or while using ngrok.
RETELL_FUNCTION_URL=https://YOUR-HOST/retell/function
RETELL_WEBHOOK_URL=https://YOUR-HOST/retell/webhook

# Retell LLM model and voice (optional — defaults shown).
RETELL_MODEL=claude-3.5-haiku
RETELL_VOICE_ID=11labs-Adrian

# ── GoHighLevel ───────────────────────────────────────────────────────────────
# Private Integration token for your GHL sub-account (location).
# Scopes needed: calendars.readonly, calendars.write, contacts.write
GHL_API_TOKEN=
GHL_LOCATION_ID=
GHL_CALENDAR_ID=

# Appointment slot length in minutes (default 30).
GHL_SLOT_MINUTES=30

# ── Encryption (generate with: python -m app.crypto) ──────────────────────────
# AES-256 key for PHI at rest. Generate once; never change after real data exists.
ENCRYPTION_KEY=

# HMAC key for one-way phone fingerprinting. Any long random string.
PHONE_HASH_HMAC_KEY=

# ── Staff Dashboard ───────────────────────────────────────────────────────────
# Token to access /dashboard and /api/calls. Any long random string.
DASHBOARD_TOKEN=

# ── Database ──────────────────────────────────────────────────────────────────
# Defaults to a local SQLite file for dev. Use a Postgres URL in production.
DATABASE_URL=sqlite:///./clinic.db

# ── Clinic ────────────────────────────────────────────────────────────────────
CLINIC_TZ=America/Indiana/Indianapolis

# ── Twilio SMS (optional) ─────────────────────────────────────────────────────
# Only needed if YOU want to send SMS; GHL can also send its own confirmations.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Dashboard & operations (added Jul 2026) ---
# DASHBOARD_TOKEN=long-random-string          # required for /dashboard + /api/*
# DIGEST_TO_NUMBER=+13175550000               # where the daily digest SMS goes
# DIGEST_HOUR=7                               # local hour for auto digest (unset = manual/cron only)
# REMINDER_HOUR=16                            # local hour for day-before reminders ("" disables loop)
# AUTO_SYNC_HOURS=6                           # pull Retell history every N hours (0 disables)
# CLINIC_NAME=Bright Smile Dental & Aesthetics   # clinic row #1 name (multi-clinic foundation)
# SERVICE_PRICES_JSON={"exam":89,"cleaning":120,"whitening":199,"default":100}  # revenue estimates
# DASHBOARD_SECRET=another-long-random-string   # signs login session cookies (falls back to PHONE_HASH_HMAC_KEY)
# DASHBOARD_ADMIN_USER=owner                    # first admin (created at startup if no users exist)
# DASHBOARD_ADMIN_PASSWORD=change-me-8chars+
# WAITLIST_NOTIFY=sms                           # sms | call | off — how freed slots are offered
# OUTBOUND_ON_RESCHEDULE=0                      # 1 = Sarah calls back when a patient texts R
# SMS_WEBHOOK_URL=https://YOUR-HOST/sms/inbound # set in Twilio console (Messaging webhook); used for signature validation
